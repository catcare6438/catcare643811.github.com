<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>浪貓不浪 🐾 貓咪管理系統</title>
    <style>
        :root { --p: #ff8fab; --bg: #fffcfd; }
        body { font-family: -apple-system, sans-serif; background: var(--bg); margin: 0; padding-bottom: 50px; color: #444; }
        header { background: white; padding: 20px; text-align: center; border-bottom: 1px solid #eee; position: sticky; top: 0; z-index: 100; }
        .container { padding: 15px; display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
        .card { background: white; border-radius: 15px; overflow: hidden; box-shadow: 0 4px 10px rgba(0,0,0,0.05); border: 1px solid #f0f0f0; text-align: center; }
        .card img { width: 100%; height: 120px; object-fit: cover; background: #ffeef2; }
        .card-body { padding: 10px; }
        .card-body h3 { margin: 0; font-size: 1rem; color: var(--p); }
        .card-body p { margin: 5px 0 0; font-size: 0.75rem; color: #999; }
        .loading { grid-column: 1/-1; text-align: center; padding: 100px 0; color: var(--p); font-weight: bold; }
    </style>
</head>
<body>

<header><h1 style="margin:0; font-size:1.2rem; color:var(--p);">🐾 浪貓不浪 貓咪名單</h1></header>

<div id="app" class="container">
    <div class="loading">正在連線試算表資料...</div>
</div>

<script>
    // 直接讀取你的試算表 CSV 格式
    const SHEET_ID = "1TW2VudIow-Vzr5uz5nToFTQfxCCMyUVqi48pYmBw8fs";
    const CSV_URL = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/export?format=csv`;

    async function loadData() {
        try {
            const response = await fetch(CSV_URL);
            const data = await response.text();
            
            // 解析 CSV 內容
            const rows = data.split('\n').map(row => {
                // 處理 CSV 內容中的引號與逗號
                return row.split(/,(?=(?:(?:[^"]*"){2})*[^"]*$)/);
            }).slice(1); // 跳過標題

            let html = "";
            rows.forEach(col => {
                const name = (col[0] || "").replace(/"/g, "").trim();
                const color = (col[7] || "").replace(/"/g, "").trim();
                const age = (col[8] || "").replace(/"/g, "").trim();
                
                if (name && name !== "貓名字") {
                    html += `
                    <div class="card">
                        <div style="height:100px; display:flex; align-items:center; justify-content:center; background:#fff0f3; color:#ffb6c1; font-weight:bold;">${name}</div>
                        <div class="card-body">
                            <h3>${name}</h3>
                            <p>${age}</p>
                            <p style="color:#ffc1cc">${color}</p>
                        </div>
                    </div>`;
                }
            });
            document.getElementById('app').innerHTML = html || "試算表內沒有資料喔！";
        } catch (e) {
            document.getElementById('app').innerHTML = "讀取失敗，請確認試算表已開啟「知道連結的人均可檢視」。";
        }
    }
    loadData();
</script>
</body>
</html>
